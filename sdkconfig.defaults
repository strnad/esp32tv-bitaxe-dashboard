# NM-TV-154 Hardware Configuration
# ESP32-D0 (ESP32-WROOM-32), 4MB Flash, 240MHz

# Flash: 4MB, DIO mode, 40MHz
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y

# CPU: 240MHz
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Custom partition table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Touch button: T9 = GPIO 32 (confirmed by on-device diagnostic)
CONFIG_NMTV_TOUCH_PAD_NUM=9

# LVGL: use Kconfig instead of lv_conf.h
CONFIG_LV_CONF_SKIP=y
CONFIG_LV_COLOR_DEPTH_16=y

# Additional fonts for dashboard
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_28=y
